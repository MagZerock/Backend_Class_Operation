generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  userId               String              @id @map("user_id")
  name                 String
  email                String              @unique
  phone                String?
  passwordHash         String              @map("password_hash")
  role                 String              @default("customer")
  preferences          Json                @default("{}")
  passwordResetToken   String?             @map("password_reset_token")
  passwordResetExpiresAt DateTime?         @map("password_reset_expires_at") @db.Timestamptz
  createdAt            DateTime            @default(now()) @map("created_at") @db.Timestamptz

  sessions        UserSession[]
  shoppingCart    ShoppingCart?
  orders          Order[]
  reservations    Reservation[]
  surveyResponses SurveyResponse[]

  @@map("users")
}

model UserSession {
  sessionId    BigInt   @id @default(autoincrement()) @map("session_id")
  userId       String   @map("user_id")
  refreshToken String   @unique @map("refresh_token")
  isRevoked    Boolean  @default(false) @map("is_revoked")
  expiresAt    DateTime @map("expires_at") @db.Timestamptz
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@map("user_sessions")
}

model MenuCategory {
  categoryId  String   @id @map("category_id")
  name        String
  description String?
  sortOrder   Int      @default(0) @map("sort_order")
  active      Boolean  @default(true)

  menuItems MenuItem[]

  @@map("menu_categories")
}

model MenuItem {
  itemId             String               @id @map("item_id")
  name               String
  description        String?
  price              Decimal              @db.Decimal(10, 2)
  categoryId         String?              @map("category_id")
  imageUrl           String?              @map("image_url")
  isAvailable        Boolean              @default(true) @map("is_available")
  availabilityReason String?              @map("availability_reason")
  createdAt          DateTime             @default(now()) @map("created_at") @db.Timestamptz

  category    MenuCategory?        @relation(fields: [categoryId], references: [categoryId], onDelete: SetNull)
  ingredients MenuItemIngredient[]
  cartItems   ShoppingCartItem[]
  orderItems  OrderItem[]

  @@map("menu_items")
}

model Ingredient {
  skuCode           String   @id @map("sku_code")
  name              String
  category          String?
  description       String?
  unitOfMeasurement String   @map("unit_of_measurement")
  unitCost          Decimal  @map("unit_cost") @db.Decimal(10, 2)

  inventories          Inventory[]
  menuItemIngredients  MenuItemIngredient[]

  @@map("ingredients")
}

model Inventory {
  inventoryId  String   @id @map("inventory_id")
  skuCode      String   @map("sku_code")
  currentStock Decimal  @default(0.00) @map("current_stock") @db.Decimal(12, 2)
  reorderLevel Decimal  @default(10.00) @map("reorder_level") @db.Decimal(12, 2)
  supplier     String?
  expiryDate   DateTime? @map("expiry_date") @db.Date
  updatedAt    DateTime @default(now()) @map("updated_at") @db.Timestamptz

  ingredient Ingredient @relation(fields: [skuCode], references: [skuCode], onDelete: Cascade)

  @@map("inventory")
}

model MenuItemIngredient {
  itemId           String  @map("item_id")
  skuCode          String  @map("sku_code")
  quantityRequired Decimal @map("quantity_required") @db.Decimal(10, 2)

  menuItem   MenuItem   @relation(fields: [itemId], references: [itemId], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [skuCode], references: [skuCode], onDelete: Cascade)

  @@id([itemId, skuCode])
  @@map("menu_item_ingredients")
}

model ShoppingCart {
  userId    String   @id @map("user_id")
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz

  user  User               @relation(fields: [userId], references: [userId], onDelete: Cascade)
  items ShoppingCartItem[]

  @@map("shopping_carts")
}

model ShoppingCartItem {
  userId   String @map("user_id")
  itemId   String @map("item_id")
  quantity Int

  cart ShoppingCart @relation(fields: [userId], references: [userId], onDelete: Cascade)
  item MenuItem    @relation(fields: [itemId], references: [itemId], onDelete: Cascade)

  @@id([userId, itemId])
  @@map("shopping_cart_items")
}

model Order {
  orderId             String   @id @map("order_id")
  userId              String?  @map("user_id")
  totalAmount         Decimal  @map("total_amount") @db.Decimal(10, 2)
  status              String   @default("pending")
  deliveryType        String   @map("delivery_type")
  deliveryAddress     String?  @map("delivery_address")
  specialInstructions String?  @map("special_instructions")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz

  user  User?       @relation(fields: [userId], references: [userId], onDelete: SetNull)
  items OrderItem[]

  @@map("orders")
}

model OrderItem {
  orderItemId     BigInt   @id @default(autoincrement()) @map("order_item_id")
  orderId         String   @map("order_id")
  itemId          String?  @map("item_id")
  quantity        Int
  priceAtPurchase Decimal  @map("price_at_purchase") @db.Decimal(10, 2)

  order Order    @relation(fields: [orderId], references: [orderId], onDelete: Cascade)
  item  MenuItem? @relation(fields: [itemId], references: [itemId], onDelete: SetNull)

  @@map("order_items")
}

model Reservation {
  reservationId   String   @id @map("reservation_id")
  userId          String?  @map("user_id")
  reservationDate DateTime @map("reservation_date") @db.Date
  reservationTime DateTime @map("reservation_time") @db.Time
  partySize       Int      @map("party_size")
  specialRequests String?  @map("special_requests")
  status          String   @default("pending")

  user User? @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@map("reservations")
}

model Survey {
  surveyId String @id @map("survey_id")
  title    String
  isActive Boolean @default(true) @map("is_active")

  responses SurveyResponse[]

  @@map("surveys")
}

model SurveyResponse {
  responseId BigInt   @id @default(autoincrement()) @map("response_id")
  surveyId   String   @map("survey_id")
  userId     String?  @map("user_id")
  questionId String   @map("question_id")
  answer     String
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  survey Survey @relation(fields: [surveyId], references: [surveyId], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [userId], onDelete: SetNull)

  @@map("survey_responses")
}
